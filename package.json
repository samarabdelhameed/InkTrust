{
  "name": "inktrust-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "InkTrust — The Analog-to-Onchain Bridge for Elderly Digital Inclusion",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "pnpm --filter web-dashboard dev",
    "dev:api": "pnpm --filter api-server dev",
    "infra:up": "docker-compose -f infrastructure/docker/docker-compose.yml up -d",
    "infra:down": "docker-compose -f infrastructure/docker/docker-compose.yml down",
    "db:setup": "pnpm db:generate && pnpm db:migrate",
    "db:seed:demo": "tsx packages/db-schema/src/seed-demo.ts",
    "db:seed": "pnpm --filter db-schema seed",
    "db:studio": "pnpm --filter db-schema studio",
    "db:push": "pnpm --filter db-schema push",
    "db:reset": "pnpm --filter db-schema migrate:reset",
    "build:web": "pnpm --filter web-dashboard build",
    "build:api": "pnpm --filter api-server build",
    "anchor:build": "cd anchor && anchor build",
    "anchor:test": "cd anchor && anchor test",
    "anchor:deploy": "cd anchor && anchor deploy",
    "db:generate": "pnpm --filter db-schema generate",
    "db:migrate": "pnpm --filter db-schema migrate",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "keywords": [
    "solana",
    "blockchain",
    "ai-agents",
    "elderly-care",
    "analog-bridge",
    "mcp",
    "gemini",
    "metaplex",
    "swig"
  ],
  "author": "Samar Abdelhameed",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
