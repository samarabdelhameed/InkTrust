model AuditLog {
  id             String   @id @default(uuid())
  actorId        String?  @map("actor_id")
  faxRequestId   String?  @map("fax_request_id")
  email          String?
  action         String
  resource       String
  resourceId     String?  @map("resource_id")
  details        Json?
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at")

  faxRequest FaxRequest? @relation(fields: [faxRequestId], references: [id])
  user       User?       @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([faxRequestId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
