generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 1. USERS & IDENTITY
// ============================================================
model User {
  id                      String    @id @default(uuid())
  faxNumber               String    @unique
  proxyEmail              String?   @unique
  embeddedWalletAddress   String    @unique
  caregiverWalletAddress  String?
  worldIdVerified         Boolean   @default(false)
  spendingLimit           Decimal   @default(0.0) @db.Decimal(18, 8)
  accountStatus           UserStatus @default(ACTIVE)
  onboardingCompleted     Boolean   @default(false)
  
  lastActivityAt          DateTime  @default(now())
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  deletedAt               DateTime?

  // Relations
  trustedContacts         TrustedContact[]
  jobs                    Job[]
  medicalRecords          MedicalRecord[]
  transactions            FinancialTransaction[]
  agentIdentities         AgentIdentity[]
  artifacts               FileArtifact[]
  approvals               Approval[]

  @@index([embeddedWalletAddress])
  @@index([faxNumber])
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  UNDER_REVIEW
  DELETED
}

// ============================================================
// 2. PHISHING-RESISTANT TRUSTED CONTACTS
// ============================================================
model TrustedContact {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  contactEmail    String
  relationship    String
  trustLevel      Int      @default(1)
  isVerified      Boolean  @default(false)
  publicKey       String?  // Optional on-chain identity
  createdAt       DateTime @default(now())

  @@unique([userId, contactEmail])
}

// ============================================================
// 3. AI ORCHESTRATION & JOBS
// ============================================================
model Job {
  id                String      @id @default(uuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id])
  intentType        String
  intentHash        String      @unique // Links to Solana PDA
  aiSummary         String?     @db.Text
  extractedEntities Json?
  confidenceScore   Float?
  status            JobStatus   @default(PENDING)
  priority          Int         @default(0)
  requiresApproval  Boolean     @default(true)
  approvalStatus    ApprovalStatus @default(PENDING)
  
  queueId           String?     // BullMQ Job ID
  retryCount        Int         @default(0)
  
  createdAt         DateTime    @default(now())
  completedAt       DateTime?

  // Relations
  reviews           HumanReview[]
  transactions      FinancialTransaction[]
  artifacts         FileArtifact[]
  approvals         Approval[]

  @@index([userId, status])
}

enum JobStatus {
  PENDING
  PROCESSING
  AWAITING_APPROVAL
  EXECUTING
  COMPLETED
  FAILED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

// ============================================================
// 4. HUMAN-IN-THE-LOOP & AUDIT
// ============================================================
model HumanReview {
  id              String   @id @default(uuid())
  jobId           String
  job             Job      @relation(fields: [jobId], references: [id])
  flagReason      String?
  riskScore       Float?
  operatorAction  String?
  operatorNotes   String?  @db.Text
  escalationLevel Int      @default(0)
  reviewedBy      String?
  reviewedAt      DateTime?
}

// ============================================================
// 5. HYBRID FINANCIAL TRANSACTIONS
// ============================================================
model FinancialTransaction {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id])
  jobId             String?
  job               Job?      @relation(fields: [jobId], references: [id])
  
  txSignature       String?   @unique // Solana Signature
  blockchainNetwork String    @default("devnet")
  tokenMint         String?   // SPL Token Mint Address
  paymentProvider   String?   // e.g., "solana", "stripe", "virtual-card"
  virtualCardId     String?
  
  status            TxStatus  @default(PENDING)
  amount            Decimal   @db.Decimal(18, 8)
  currency          String    @default("SOL")
  gasFees           Decimal?  @db.Decimal(18, 8)
  executedAt        DateTime?
  
  createdAt         DateTime  @default(now())

  @@index([txSignature])
  @@index([userId, status])
}

enum TxStatus {
  PENDING
  CONFIRMED
  FAILED
  REVERSED
}

// ============================================================
// 6. AI AGENT REGISTRY
// ============================================================
model AgentIdentity {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  metaplexAssetId String?  @unique // Metaplex Core Asset ID
  embeddedWallet  String   @unique
  executionScope  Json?    // Define what the agent can do
  sponsorPermissions Json?
  policyEngineId  String?
  activeStatus    Boolean  @default(true)
  lastExecutionAt DateTime?
}

// ============================================================
// 7. FILE ARTIFACTS (S3)
// ============================================================
model FileArtifact {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  jobId           String?
  job             Job?     @relation(fields: [jobId], references: [id])
  
  s3Key           String   @unique
  artifactType    String   // e.g., "FAX_IMAGE", "AI_REPORT", "RECEIPT"
  mimeType        String
  encryptionStatus Boolean  @default(false)
  uploadedAt      DateTime @default(now())
}

// ============================================================
// 8. POLICY & APPROVAL ORCHESTRATION
// ============================================================
model Approval {
  id                String         @id @default(uuid())
  jobId             String
  job               Job            @relation(fields: [jobId], references: [id])
  userId            String
  user              User           @relation(fields: [userId], references: [id])
  
  policyType        String         // e.g., "THRESHOLD", "WHITELIST"
  requiredSigners   Int            @default(1)
  receivedSigners   Int            @default(0)
  approvalDeadline  DateTime?
  nonceAccount      String?        // Durable Nonce Account Pubkey
  
  status            ApprovalStatus @default(PENDING)
  finalizedAt       DateTime?
  createdAt         DateTime       @default(now())
}

// Existing model migration/update
model MedicalRecord {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  encryptedData   String
  documentType    String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AILog {
  id              String   @id @default(uuid())
  prompt          String
  response        String?
  modelUsed       String
  executionTimeMs Int?
  createdAt       DateTime @default(now())
}

model AuditLog {
  id              String   @id @default(uuid())
  action          String
  entityType      String
  entityId        String
  actorId         String?
  timestamp       DateTime @default(now())
  details         Json?
}

model QueueJob {
  id              String   @id @default(uuid())
  queueName       String
  jobId           String   @unique
  status          String
  data            Json
  error           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
