generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid())
  faxNumber       String   @unique @map("fax_number")
  proxyEmail      String   @unique @map("proxy_email")
  embeddedWallet  String   @unique @map("embedded_wallet")
  dailySpendLimit Int      @default(3000) @map("daily_spend_limit")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  caregivers      Caregiver[]
  faxRequests     FaxRequest[]
  trustedContacts TrustedContact[]
  roles           UserRole[]
  medicalRecords  MedicalRecord[]
  transactions    TransactionRecord[]
  auditEntries    AuditLog[]
  approvals       ApprovalWorkflow[]

  @@map("users")
}

model Caregiver {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  walletAddress String        @map("wallet_address")
  name          String
  phone         String
  role          CaregiverRole @default(PRIMARY)
  createdAt     DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("caregivers")
}

model FaxRequest {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  status        RequestStatus @default(RECEIVED)
  faxMediaUrl   String        @map("fax_media_url")
  aiIntent      Json?         @map("ai_intent")
  onchainPda    String?       @map("onchain_pda")
  blinkUrl      String?       @map("blink_url")
  amountJpy     Int?          @map("amount_jpy")
  txSignature   String?       @map("tx_signature")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user            User              @relation(fields: [userId], references: [id])
  aiLogs          AiProcessingLog[]
  approvals       ApprovalWorkflow[]
  auditEntries    AuditLog[]

  @@map("fax_requests")
}

model TrustedContact {
  id           String @id @default(uuid())
  userId       String @map("user_id")
  email        String
  name         String
  relationship String
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("trusted_contacts")
}

model AuditLog {
  id             String   @id @default(uuid())
  actorId        String?  @map("actor_id")
  faxRequestId   String?  @map("fax_request_id")
  email          String?
  action         String
  resource       String
  resourceId     String?  @map("resource_id")
  details        Json?
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at")

  faxRequest FaxRequest? @relation(fields: [faxRequestId], references: [id])
  user       User?       @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([faxRequestId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model AiProcessingLog {
  id           String   @id @default(uuid())
  faxRequestId String   @map("fax_request_id")
  model        String   @default("gemini-2.0-flash")
  promptTokens Int?     @map("prompt_tokens")
  outputTokens Int?     @map("output_tokens")
  confidence   Float?
  rawResponse  Json?
  intent       Json?
  error        String?
  processingMs Int?     @map("processing_ms")
  createdAt    DateTime @default(now()) @map("created_at")

  faxRequest FaxRequest @relation(fields: [faxRequestId], references: [id])

  @@index([faxRequestId])
  @@index([createdAt])
  @@map("ai_processing_logs")
}

model QueueJob {
  id         String   @id @default(uuid())
  queueName  String   @map("queue_name")
  jobType    String   @map("job_type")
  payload    Json?
  status     JobStatus @default(PENDING)
  priority   Int      @default(0)
  retryCount Int      @default(0) @map("retry_count")
  maxRetries Int      @default(3) @map("max_retries")
  scheduledAt DateTime? @map("scheduled_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  error       String?
  result      Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([queueName])
  @@index([status])
  @@index([scheduledAt])
  @@map("queue_jobs")
}

model UserRole {
  id     String @id @default(uuid())
  userId String @map("user_id")
  role   Role   @default(VIEWER)

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, role])
  @@map("user_roles")
}

model MedicalRecord {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  recordType    String    @map("record_type")
  encryptedData  String   @map("encrypted_data")
  encryptionIv  String    @map("encryption_iv")
  hash          String
  fileName      String?   @map("file_name")
  mimeType      String?   @map("mime_type")
  s3Key         String?   @map("s3_key")
  fileSize      Int?      @map("file_size")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([recordType])
  @@map("medical_records")
}

model TransactionRecord {
  id             String            @id @default(uuid())
  userId         String            @map("user_id")
  faxRequestId   String?           @map("fax_request_id")
  type           TransactionType
  amount         Int
  currency       String            @default("JPY")
  status         TransactionStatus @default(PENDING)
  source         String?
  destination    String?
  txSignature    String?           @map("tx_signature")
  providerRef    String?           @map("provider_ref")
  metadata       Json?
  confirmedAt    DateTime?         @map("confirmed_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id])
  faxRequest  FaxRequest?  @relation(fields: [faxRequestId], references: [id])

  @@index([userId])
  @@index([faxRequestId])
  @@index([type])
  @@index([status])
  @@map("transaction_records")
}

model SponsorPayment {
  id             String               @id @default(uuid())
  sponsorId      String               @map("sponsor_id")
  beneficiaryId  String               @map("beneficiary_id")
  amount         Int
  currency       String               @default("JPY")
  frequency      PaymentFrequency
  status         SponsorPaymentStatus @default(ACTIVE)
  startDate      DateTime             @map("start_date")
  endDate        DateTime?            @map("end_date")
  lastProcessedAt DateTime?            @map("last_processed_at")
  providerRef    String?              @map("provider_ref")
  metadata       Json?
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  @@index([sponsorId])
  @@index([beneficiaryId])
  @@index([status])
  @@map("sponsor_payments")
}

model ApprovalWorkflow {
  id            String         @id @default(uuid())
  faxRequestId  String         @map("fax_request_id")
  approverId    String         @map("approver_id")
  status        ApprovalStatus @default(PENDING)
  signature     String?
  signedAt      DateTime?      @map("signed_at")
  expiresAt     DateTime?      @map("expires_at")
  reminderSent  Boolean        @default(false) @map("reminder_sent")
  metadata      Json?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  faxRequest FaxRequest @relation(fields: [faxRequestId], references: [id])
  user       User       @relation(fields: [approverId], references: [id])

  @@unique([faxRequestId, approverId])
  @@index([faxRequestId])
  @@index([approverId])
  @@index([status])
  @@map("approval_workflows")
}

enum CaregiverRole {
  PRIMARY
  SECONDARY
}

enum RequestStatus {
  RECEIVED
  AI_PROCESSING
  INTENT_EXTRACTED
  WAITING_APPROVAL
  APPROVED
  EXECUTING
  EXECUTED
  FAILED
  CLOSED
}

enum JobStatus {
  PENDING
  ACTIVE
  DELAYED
  COMPLETED
  FAILED
  CANCELLED
}

enum Role {
  ADMIN
  CAREGIVER
  VIEWER
}

enum TransactionType {
  FAX_PURCHASE
  SPONSOR_PAYMENT
  GAS_FEE
  REFUND
  WITHDRAWAL
  DEPOSIT
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
}

enum PaymentFrequency {
  MONTHLY
  QUARTERLY
  ANNUAL
  ONE_TIME
}

enum SponsorPaymentStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  ESCALATED
}
