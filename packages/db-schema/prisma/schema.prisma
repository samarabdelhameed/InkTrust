generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// CORE MODELS
// ========================================

model User {
  id                      String    @id @default(uuid())
  faxNumber               String    @unique
  proxyEmail              String?   @unique
  embeddedWalletAddress   String    @unique
  caregiverWalletAddress  String?
  worldIdVerified         Boolean   @default(false)
  spendingLimit           Decimal   @default(0.0) @db.Decimal(18, 8)
  status                  UserStatus @default(ACTIVE)
  
  lastActivityAt          DateTime  @default(now())
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  // Relations
  faxJobs                 FaxJob[]
  approvals               ApprovalRequest[]
  trustedContacts         TrustedContact[]
  transactions            Transaction[]
  agentSessions           AgentSession[]
  verifications           WorldIdVerification[]
  spendingPolicy          SpendingPolicy?

  @@index([embeddedWalletAddress])
  @@index([faxNumber])
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model FaxJob {
  id                String      @id @default(uuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id])
  
  externalFaxId     String      @unique // Telnyx ID
  mediaUrl          String?     // S3 URL
  status            JobStatus   @default(RECEIVED)
  
  intent            String?
  amount            Decimal?    @db.Decimal(18, 8)
  merchant          String?
  medication        String?
  urgency           String?     @default("NORMAL")
  confidenceScore   Float?
  
  aiRawResponse     Json?
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  completedAt       DateTime?

  // Relations
  approvalRequest   ApprovalRequest?
  transactions      Transaction[]
  auditReview       AuditReview?
  mcpLogs           MCPExecutionLog[]

  @@index([userId, status])
}

enum JobStatus {
  RECEIVED
  PROCESSING
  AWAITING_APPROVAL
  EXECUTING
  COMPLETED
  FAILED
}

model ApprovalRequest {
  id                String         @id @default(uuid())
  faxJobId          String         @unique
  faxJob            FaxJob         @relation(fields: [faxJobId], references: [id])
  userId            String
  user              User           @relation(fields: [userId], references: [id])
  
  status            ApprovalStatus @default(PENDING)
  requiredSigners   Int            @default(1)
  receivedSigners   Int            @default(0)
  nonceAccount      String?        // Solana Durable Nonce
  
  expiresAt         DateTime
  finalizedAt       DateTime?
  createdAt         DateTime       @default(now())

  @@index([userId, status])
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

model Transaction {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id])
  faxJobId          String?
  faxJob            FaxJob?    @relation(fields: [faxJobId], references: [id])
  
  txSignature       String    @unique
  network           String    @default("devnet")
  tokenMint         String?
  amount            Decimal   @db.Decimal(18, 8)
  currency          String    @default("SOL")
  status            TxStatus  @default(CONFIRMED)
  
  createdAt         DateTime  @default(now())
}

enum TxStatus {
  PENDING
  CONFIRMED
  FAILED
}

model TrustedContact {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  email           String
  name            String
  relation        String
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@unique([userId, email])
}

model AuditReview {
  id              String   @id @default(uuid())
  faxJobId        String   @unique
  faxJob          FaxJob   @relation(fields: [faxJobId], references: [id])
  riskScore       Float
  moderatorAction String?
  moderatorNotes  String?  @db.Text
  reviewedAt      DateTime @default(now())
}

model AgentSession {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  agentId         String
  scope           Json
  expiresAt       DateTime
  createdAt       DateTime @default(now())
}

model WorldIdVerification {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  nullifierHash   String   @unique
  merkleRoot      String
  proof           String   @db.Text
  verifiedAt      DateTime @default(now())
}

model SpendingPolicy {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  dailyLimit      Decimal  @db.Decimal(18, 8)
  monthlyLimit    Decimal  @db.Decimal(18, 8)
  requiresMfa     Boolean  @default(true)
}

model MCPExecutionLog {
  id              String   @id @default(uuid())
  faxJobId        String
  faxJob          FaxJob   @relation(fields: [faxJobId], references: [id])
  toolName        String
  input           Json
  output          Json?
  status          String
  durationMs      Int
  createdAt       DateTime @default(now())
}
