# ==============================================================================
# 🌐 1. SYSTEM & APPLICATION CONFIG
# ==============================================================================
# الرابط الأساسي لتطبيقك (يُستخدم في الـ OAuth و Solana Blinks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
PORT=3000

# ==============================================================================
# ⛓️ 2. SOLANA RPC & NETWORK (HELIUS / FLUXRPC)
# ==============================================================================
# مزود العقدة السريعة لشبكة سولانا (Mainnet/Devnet)
NEXT_PUBLIC_SOLANA_RPC_URL="https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY"

# ==============================================================================
# 🧠 3. AI ORCHESTRATOR & AGENT IDENTITY
# ==============================================================================
# مفتاح نموذج Gemini لفك شفرة الفاكس
GEMINI_API_KEY="your_gemini_2_0_flash_api_key"

# المفتاح الخاص (Base58) لمحفظة الوكيل الذكي المسجلة كـ Core NFT عبر Metaplex
AGENT_PRIVATE_KEY="your_agent_wallet_private_key_base58"

# ==============================================================================
# 📠 4. ANALOG TELECOM (TELNYX FAX API)
# ==============================================================================
# مفاتيح شركة Telnyx لاستقبال وإرسال الفاكس
TELNYX_API_KEY="your_telnyx_api_key"
TELNYX_WEBHOOK_SECRET="your_telnyx_webhook_signing_secret"
# رقم الفاكس الأساسي للنظام (الذي سيرسل إليه المسنون)
SYSTEM_FAX_NUMBER="+81-50-5050-8899"

# ==============================================================================
# 🔑 5. EMBEDDED WALLETS & AUTH (PHANTOM & PRIVY)
# ==============================================================================
# معرّف التطبيق من بوابة Phantom Portal لتمكين تسجيل الدخول الاجتماعي
NEXT_PUBLIC_PHANTOM_APP_ID="your_phantom_portal_app_id"

# مفاتيح Privy لإنشاء المحافظ المدمجة (Embedded Wallets) للمسنين
NEXT_PUBLIC_PRIVY_APP_ID="your_privy_app_id"
PRIVY_APP_SECRET="your_privy_backend_secret"

# ==============================================================================
# 💸 6. PAYMENTS, GASLESS & x402 PROTOCOLS
# ==============================================================================
# مفاتيح Coinbase CDP لتفعيل مدفوعات الوكيل المصغرة (x402)
COINBASE_CDP_API_KEY_NAME="your_cdp_api_key_name"
COINBASE_CDP_API_KEY_PRIVATE_KEY="your_cdp_private_key"

# مفتاح محرك Swig لتحمل رسوم الغاز (Gasless) وتطبيق حدود الإنفاق
SWIG_API_KEY="your_swig_smart_wallet_api_key"

# ==============================================================================
# 💳 7. REAL-WORLD COMMERCE (MOONPAY)
# ==============================================================================
# مفاتيح MoonPay للسماح للوكيل بإنشاء بطاقات افتراضية للشراء من أمازون اليابان
MOONPAY_SECRET_KEY="your_moonpay_secret_key"

# ==============================================================================
# 🛡️ 8. PRIVACY & SYBIL RESISTANCE (ARCIUM & WORLD ID)
# ==============================================================================
# مزود Arcium لتشفير البيانات الطبية قبل إرسالها للعقد الذكي
ARCIUM_RPC_URL="https://arcium-network-rpc-endpoint"

# مفاتيح World ID (IDKit) للتحقق من أن مقدم الرعاية إنسان حقيقي وليس روبوت
NEXT_PUBLIC_WORLD_ID_APP_ID="app_XXXXXXXXX"
NEXT_PUBLIC_WORLD_ID_ACTION="verify_caregiver_action"

# ==============================================================================
# 🗄️ 9. DATABASE & QUEUES (POSTGRESQL & REDIS)
# ==============================================================================
# رابط قاعدة البيانات لتخزين السياق والجداول (Off-chain)
DATABASE_URL="postgresql://user:password@localhost:5432/inktrust_db"
# رابط Redis لتشغيل طوابير مهام BullMQ الخاصة بالفاكس الوارد
REDIS_URL="redis://localhost:6379"
