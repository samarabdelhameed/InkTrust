# ============================================================
# InkTrust — Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in your values.
# ============================================================

# Solana
NEXT_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# AI / Vision
GEMINI_API_KEY=your_gemini_api_key

# Fax Gateway
TELNYX_API_KEY=your_telnyx_api_key
TELNYX_FAX_WEBHOOK_URL=https://your-domain.com/api/webhooks/telnyx

# Auth & Wallets
PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret

# Commerce
MOONPAY_API_KEY=your_moonpay_api_key

# Micropayments
X402_COINBASE_API_KEY=your_x402_key

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/inktrust

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Server
PORT=3001
